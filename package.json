  "main": "dist/index.js",
  "scripts": {
    "start": "vite",
    "test": "vitest run",
    "coverage": "pnpm test -- --coverage",
    "mutate": "stryker run",
    "preview": "vite preview",
    "build": "vite build && pnpm typecheck",
    "typecheck": "tsc",
    "oxfmt": "oxfmt --check .",
    "format": "oxfmt --write .",
    "lint": "pnpm lint:ts && pnpm oxfmt && pnpm lint:md",
    "lint:ts": "oxlint .",
    "lint:md": "markdownlint-cli2 .",
    "build:i18n": "paraglide-js compile --project ./project.inlang --outdir ./src/paraglide",
    "machine-translate": "inlang machine translate --project project.inlang"
  },
  "dependencies": {
    "@tabler/icons-react": "3.44.0",
    "immer": "11.1.8",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@axe-core/react": "4.12.1",
    "@inlang/cli": "3.1.14",
    "@inlang/paraglide-js": "2.20.2",
    "@stryker-mutator/core": "9.6.1",
    "@stryker-mutator/vitest-runner": "9.6.1",
    "@tailwindcss/vite": "4.3.1",
    "@types/node": "26.0.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "daisyui": "5.6.3",
    "markdownlint": "0.41.0",
    "markdownlint-cli2": "0.22.1",
    "oxfmt": "0.56.0",
    "oxlint": "1.71.0",
    "oxlint-tsgolint": "0.23.0",
    "radash": "12.1.1",
    "tailwindcss": "4.3.1",
    "typescript": "6.0.3",
    "vite": "8.1.0",
    "vitest": "4.1.9"
  }
}
